<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Vista del transportista EnviaTodo para Custer Boots
        Hereda la vista base de delivery.carrier y agrega
        los campos de configuración de EnviaTodo.

        Nota: Usa la sintaxis de Odoo 17+ para invisibilidad:
              invisible="delivery_type != 'enviatodo'"
              NO se usa attrs={'invisible': [...]}
    -->
    <record id="view_delivery_carrier_form_enviatodo" model="ir.ui.view">
        <field name="name">delivery.carrier.form.enviatodo</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">

            <!-- Insertar la página de configuración de EnviaTodo
                 después de la página de configuración general -->
            <xpath expr="//page[@name='pricing']" position="after">
                <page
                    name="enviatodo_config"
                    string="EnviaTodo"
                    invisible="delivery_type != 'enviatodo'">

                    <!-- ================================================
                         SECCIÓN: Credenciales de la API
                         ================================================ -->
                    <group string="Credenciales de la API" name="enviatodo_credentials">
                        <group>
                            <field
                                name="x_studio_api_key_enviatodo"
                                password="True"
                                placeholder="Ingrese su API Key de EnviaTodo"
                                required="delivery_type == 'enviatodo'"
                            />
                            <field
                                name="x_studio_usuario_enviatodo"
                                placeholder="ID de usuario o cuenta"
                                required="delivery_type == 'enviatodo'"
                            />
                        </group>
                        <group>
                            <field
                                name="x_studio_url_base_api"
                                placeholder="https://apiqav2.enviatodo.mx/index.php/"
                            />
                            <!-- Botón de prueba de conexión -->
                            <div class="o_field_widget">
                                <button
                                    name="action_enviatodo_test_connection"
                                    type="object"
                                    string="Probar conexión"
                                    class="btn btn-secondary"
                                    icon="fa-plug"
                                />
                            </div>
                        </group>
                    </group>

                    <!-- ================================================
                         SECCIÓN: Configuración del Servicio
                         ================================================ -->
                    <group string="Configuración del Servicio" name="enviatodo_service">
                        <group>
                            <field
                                name="x_studio_tipo_de_servicio"
                                placeholder="express"
                            />
                            <field
                                name="x_studio_cp_de_origen"
                                placeholder="37000"
                            />
                        </group>
                        <group>
                            <div class="alert alert-info" role="alert">
                                <strong>Datos de origen Custer Boots:</strong><br/>
                                León, Guanajuato — CP 37000<br/>
                                Tipos de servicio disponibles: consultar con EnviaTodo.
                            </div>
                        </group>
                    </group>

                    <!-- ================================================
                         SECCIÓN: Dimensiones Predeterminadas del Paquete
                         ================================================ -->
                    <group
                        string="Dimensiones Predeterminadas del Paquete"
                        name="enviatodo_dimensions">
                        <group string="Medidas (cm)">
                            <field
                                name="x_studio_largo_cm_1"
                                string="Largo (cm)"
                            />
                            <field
                                name="x_studio_ancho_cm_1"
                                string="Ancho (cm)"
                            />
                            <field
                                name="x_studio_alto_cm_1"
                                string="Alto (cm)"
                            />
                        </group>
                        <group string="Peso">
                            <field
                                name="x_studio_peso_kg"
                                string="Peso (kg)"
                            />
                            <div class="alert alert-warning" role="alert">
                                <strong>Dimensiones de caja Custer Boots:</strong><br/>
                                44 cm × 11 cm × 33 cm — 1.9 kg<br/>
                                Si el picking tiene productos con peso configurado,
                                se usará el peso real calculado.
                            </div>
                        </group>
                    </group>

                </page>
            </xpath>

        </field>
    </record>
</odoo>
